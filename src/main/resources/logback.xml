<configuration>
    <property name="LOG_LEVEL" value="${bytecodevm.log.level:-INFO}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%cyan([%d{HH:mm:ss}]) %highlight([%thread/%-5level]) %green([%logger{0}]): %msg%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
